{
  "entities": {
    "VisitorLog": {
      "title": "Visitor Log",
      "description": "A record of a library visit entry.",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "name": { "type": "string" },
        "reason": { "type": "string" },
        "college": { "type": "string" },
        "isEmployee": { "type": "boolean" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "name", "reason", "college", "timestamp"]
    }
  },
  "auth": {
    "providers": ["google.com"]
  },
  "firestore": {
    "/visitor_logs/{logId}": {
      "schema": "VisitorLog",
      "description": "Collection of visitor entry logs."
    }
  }
}